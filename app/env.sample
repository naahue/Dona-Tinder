DJANGO_SECRET_KEY=cambiar-en-produccion-largo-y-aleatorio
DJANGO_DEBUG=false
# Fuera de este stack local, suele usarse DJANGO_SERVE_MEDIA=false y servir /media/ con el proxy (lo adaptás al despliegue).
DJANGO_SERVE_MEDIA=false
DJANGO_ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DATABASE_URL=sqlite:///db.sqlite3
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@tu-dominio.com
SENTRY_DSN=

# Docker Compose: el servicio web recibe DATABASE_URL a Postgres; no hace falta duplicar salvo override.
# Postgres: servicio postgres, host interno postgres:5432, usuario/clave/bd donatinder.
#
# MEDIA en local (solo si corrés manage.py/runserver fuera del contenedor):
# Por defecto es app/media/ en el proyecto (ignorado por Git). Ejemplo fuera del árbol del repo:
# DJANGO_MEDIA_ROOT=.run/media
#
# Mismo criterio para emails con backend filebased (recuperar contraseña en local):
# DJANGO_EMAIL_FILE_PATH=.run/sent_emails
#
# En Docker Compose (docker-compose.yml) las subidas están en volumen uploads_data (/app/media en el contenedor), no en app/.compose_data. Credenciales demo: README.
